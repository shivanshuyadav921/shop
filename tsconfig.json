{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@shop/common-utils": ["libs/common-utils/src"]
    }
  },
  "include": ["services/**/*", "libs/**/*"],
  "exclude": ["node_modules", "dist"]
}
