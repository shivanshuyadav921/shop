{
  "name": "shop",
  "version": "1.0.0",
  "description": "Enterprise-grade fintech payment platform",
  "private": true,
  "workspaces": [
    "libs/*",
    "services/*"
  ],
  "scripts": {
    "build": "npm run build -r",
    "test": "npm run test -r",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "dev": "npm run dev -r",
    "deploy:staging": "bash infra/deploy/staging.sh",
    "deploy:production": "bash infra/deploy/production.sh",
    "backup:full": "bash infra/backups/disaster-recovery-backup.sh",
    "restore": "bash infra/backups/disaster-recovery-restore.sh",
    "chaos:test": "bash infra/chaos/chaos-engineering-test.sh",
    "reconcile:ledger": "npm -w payment-service run reconcile:ledger",
    "verify:integrity": "npm -w ledger-service run verify:integrity",
    "healthcheck": "bash infra/healthcheck.sh",
    "logs": "kubectl logs -n shop-fintech -f",
    "status": "kubectl get all -n shop-fintech"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "^3.400.0",
    "@aws-sdk/client-secrets-manager": "^3.400.0",
    "@noble/curves": "^1.2.0",
    "@noble/hashes": "^1.3.2",
    "@opentelemetry/api": "^1.6.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.49.1",
    "@opentelemetry/resources": "^1.22.0",
    "@opentelemetry/sdk-node": "^0.49.1",
    "@opentelemetry/sdk-trace-base": "^1.22.0",
    "argon2": "^0.31.0",
    "bcryptjs": "^2.4.3",
    "decimal.js": "^10.4.3",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "libsodium-wrappers": "^0.7.13",
    "pg": "^8.11.0",
    "pg-boss": "^10.0.0",
    "pino": "^8.16.0",
    "redis": "^4.6.11",
    "tweetnacl": "^1.0.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
